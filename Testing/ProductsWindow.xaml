<Window x:Class="Testing.ProductsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Список товаров" Height="480" Width="640">
    <DockPanel LastChildFill="True">
        <!-- Верхняя панель -->
        <StackPanel DockPanel.Dock="Top" Orientation="Horizontal">
            <Label Content="Список товаров:" FontWeight="Bold"/>
        </StackPanel>

        <!-- Таблица с товарами -->
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <DataGrid x:Name="dgProducts" AutoGenerateColumns="False" CanUserResizeRows="False">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="ID" Binding="{Binding Id}" />
                    <DataGridTextColumn Header="Название" Binding="{Binding Name}" />
                    <DataGridTextColumn Header="Цена" Binding="{Binding Price,StringFormat=C2}" />
                </DataGrid.Columns>
            </DataGrid>
        </ScrollViewer>

        <!-- Поле для подробного описания выбранного товара -->
        <TextBlock Text="{Binding ElementName=dgProducts, Path=SelectedItem.Description}"
                   Margin="10" FontSize="14" TextWrapping="Wrap"/>
    </DockPanel>
</Window>