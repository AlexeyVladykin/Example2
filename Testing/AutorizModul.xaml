<Window x:Class="Testing.AutorizModul"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Testing"
        mc:Ignorable="d"
        Title="AutorizModul" Height="450" Width="800">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition></ColumnDefinition>
            <ColumnDefinition></ColumnDefinition>
            <ColumnDefinition></ColumnDefinition>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition></RowDefinition>
            <RowDefinition></RowDefinition>
            <RowDefinition></RowDefinition>
            <RowDefinition></RowDefinition>
            <RowDefinition></RowDefinition>
        </Grid.RowDefinitions>
        <TextBlock FontSize="20px" FontWeight="Bold" Grid.Column="1" TextAlignment="Center" VerticalAlignment="Center">Регистрация</TextBlock>
        <Label Content="Логин" Grid.Column="1" Grid.Row="1"></Label>
        <TextBox Name="login" Height="30" Grid.Column="1" Grid.Row="1"/>
        <Label Content="Пароль" Grid.Column="1" Grid.Row="2"></Label>
        <TextBox Name="password" Height="30" Grid.Column="1" Grid.Row="2"/>
        <Label Content="Повторите пароль" Grid.Column="1" Grid.Row="3"></Label>
        <TextBox Name="passwordAgain" Height="30" Grid.Column="1" Grid.Row="3"/>
        <Button Content="ЗАРЕГИСТРИРОВАТЬСЯ" Height="30" Click="Button_Click_Reg" Grid.Column="1" Grid.Row="4" VerticalAlignment="Top"/>
    </Grid>
</Window>
